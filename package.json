{
  "name": "minimal-obsidian-excalidraw-plugin",
  "version": "0.1.0",
  "description": "Minimal Obsidian plugin for Excalidraw drawings",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "excalidraw"
  ],
  "license": "MIT",
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "monkey-around": "^3.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "esbuild": "0.25.5",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  }
}
